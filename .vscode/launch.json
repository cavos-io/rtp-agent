{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug ./cmd/main.go command",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/main.go",
      "cwd": "${workspaceFolder}",
      "args": ["${input:mainCommand}"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug ./cmd/main.go console",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/main.go",
      "cwd": "${workspaceFolder}",
      "args": ["console"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug ./cmd/main.go console --audio",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/main.go",
      "cwd": "${workspaceFolder}",
      "args": ["console", "--audio"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug ./cmd/main.go connect",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/main.go",
      "cwd": "${workspaceFolder}",
      "args": ["connect", "${input:connectRoomName}", "${input:connectParticipantIdentity}"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug current Go test file",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug current Go package tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    }
  ],
  "inputs": [
    {
      "id": "mainCommand",
      "type": "pickString",
      "description": "Command for ./cmd/main.go",
      "default": "start",
      "options": ["start", "dev", "console", "download-files", "eval"]
    },
    {
      "id": "connectRoomName",
      "type": "promptString",
      "description": "Room name for ./cmd/main.go connect"
    },
    {
      "id": "connectParticipantIdentity",
      "type": "promptString",
      "description": "Participant identity for ./cmd/main.go connect",
      "default": ""
    }
  ]
}
