{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug main Go application",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd",
      "cwd": "${workspaceFolder}",
      "args": ["start"],
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug current Go test file",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Debug current Go package tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
