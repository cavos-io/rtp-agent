{
  "files.exclude": {
    "**/.claude": true,
    "**/.codex": true,
    "**/.gemini": true,
    "**/.pi": true,
    "**/.tmp": true,
    "**/.git": true
  },
  "files.watcherExclude": {
    "**/.claude/**": true,
    "**/.codex/**": true,
    "**/.gemini/**": true,
    "**/.pi/**": true,
    "**/.tmp/**": true,
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/refs/**": true
  },
  "search.exclude": {
    "**/.claude": true,
    "**/.codex": true,
    "**/.gemini": true,
    "**/.pi": true,
    "**/.tmp": true,
    "**/.git": true,
    "**/node_modules": true,
    "**/refs": true
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    }
  },
  "gopls": {
    "staticcheck": true,
    "analyses": {
      "unusedparams": true,
      "shadow": true,
      "unusedvariable": true
    }
  }
}