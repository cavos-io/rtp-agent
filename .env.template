# ============================================================================
# RTP Agent - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your credentials and configuration values
# IMPORTANT: Keep .env out of version control (add to .gitignore)
# ============================================================================

# ============================================================================
# LIVEK IT SERVER CONFIGURATION (Required for production)
# ============================================================================
# LiveKit server URL and credentials for worker registration
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Optional: LiveKit SIP configuration for warm transfer workflows
# LIVEKIT_SIP_NUMBER=+1234567890
# LIVEKIT_SIP_OUTBOUND_TRUNK=sip-trunk-id


# ============================================================================
# CORE AI SERVICES (Pick at least one LLM, STT, and TTS provider)
# ============================================================================

# --- LANGUAGE MODEL (LLM) PROVIDERS ---

# OpenAI (GPT-4, GPT-4o, GPT-4o-mini) **RECOMMENDED**
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (Claude 3 series)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google Vertex AI / Gemini
GOOGLE_API_KEY=your-google-api-key
# OR use service account for Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account.json

# AWS Bedrock (multi-model support)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Groq (Fast inference)
GROQ_API_KEY=gsk-your-groq-api-key

# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key

# xAI (Grok)
XAI_API_KEY=your-xai-api-key

# Fireworks AI
FIREWORKS_API_KEY=your-fireworks-api-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Baseten
BASETEN_API_KEY=your-baseten-api-key

# Hume AI
HUME_API_KEY=your-hume-api-key

# Inworld AI
INWORLD_API_KEY=your-inworld-api-key
INWORLD_API_SECRET=your-inworld-api-secret

# Langchain integration
LANGCHAIN_API_KEY=your-langchain-api-key


# --- SPEECH-TO-TEXT (STT) PROVIDERS ---

# OpenAI Whisper **RECOMMENDED**
# Uses OPENAI_API_KEY above

# Google Cloud Speech-to-Text
# Uses GOOGLE_API_KEY / GOOGLE_APPLICATION_CREDENTIALS above

# AWS Transcribe Streaming
# Uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION above

# Deepgram
DEEPGRAM_API_KEY=your-deepgram-api-key

# Gladia
GLADIA_API_KEY=your-gladia-api-key

# Groq (Whisper integration)
# Uses GROQ_API_KEY above

# AssemblyAI
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# FAL.ai
FAL_API_KEY=your-fal-api-key

# Fireworks AI
# Uses FIREWORKS_API_KEY above

# Rtzr (Real Time Zone Recognition)
RTZR_API_KEY=your-rtzr-api-key

# Soniox
SONIOX_API_KEY=your-soniox-api-key

# Speechmatics
SPEECHMATICS_API_KEY=your-speechmatics-api-key

# Spitch
SPITCH_API_KEY=your-spitch-api-key

# Telnyx
TELNYX_API_KEY=your-telnyx-api-key


# --- TEXT-TO-SPEECH (TTS) PROVIDERS ---

# OpenAI TTS **RECOMMENDED**
# Uses OPENAI_API_KEY above

# Google Cloud Text-to-Speech
# Uses GOOGLE_API_KEY / GOOGLE_APPLICATION_CREDENTIALS above

# AWS Polly
# Uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION above

# Eleven Labs (High-quality voices)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Cartesia (Low-latency TTS)
CARTESIA_API_KEY=your-cartesia-api-key

# Azure Speech Services
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=your-azure-speech-region

# Deepgram
# Uses DEEPGRAM_API_KEY above

# Neuphonic
NEUPHONIC_API_KEY=your-neuphonic-api-key

# LMNT (Expressive TTS)
LMNT_API_KEY=your-lmnt-api-key

# Rime (Audio Intelligence)
RIME_API_KEY=your-rime-api-key

# Resemble AI
RESEMBLE_API_KEY=your-resemble-api-key

# Speechify
SPEECHIFY_API_KEY=your-speechify-api-key

# Spitch
# Uses SPITCH_API_KEY above

# Fishaudio
FISHAUDIO_API_KEY=your-fishaudio-api-key

# Minimax
MINIMAX_API_KEY=your-minimax-api-key

# Cambai (ByteDance)
CAMBAI_API_KEY=your-cambai-api-key

# Clova (Naver)
CLOVA_API_KEY=your-clova-api-key

# Telnyx
# Uses TELNYX_API_KEY above

# Ultravox (Fixie.ai)
ULTRAVOX_API_KEY=your-ultravox-api-key


# ============================================================================
# AVATAR / VIDEO PROVIDERS (Optional)
# ============================================================================

# Simli (AI Avatar)
SIMLI_API_KEY=your-simli-api-key

# Hedra (Video Generation)
HEDRA_API_KEY=your-hedra-api-key

# Tavus (Digital Humans)
TAVUS_API_KEY=your-tavus-api-key

# Lemonslice (Avatar)
LEMONSLICE_API_KEY=your-lemonslice-api-key

# Bithuman (Avatar)
BITHUMAN_API_KEY=your-bithuman-api-key

# Avatario
AVATARIO_API_KEY=your-avatario-api-key

# Avatartalk
AVATARTALK_API_KEY=your-avatartalk-api-key


# ============================================================================
# UTILIT Y SERVICES & TOOLS
# ============================================================================

# Voice Activity Detection (VAD)
# Silero VAD is built-in (no API key needed)

# Turn Detection
# Built-in support for STT-based, VAD-based, and manual modes

# Async AI (Async capabilities)
ASYNCAI_API_KEY=your-asyncai-api-key

# Anam (Analytics)
ANAM_API_KEY=your-anam-api-key

# Computer Tool (for Anthropic Claude)
# Used for Claude's vision and tool use capabilities

# Browser Automation
# Browser automation support is built-in via Puppeteer/Playwright


# ============================================================================
# LOGGING & OBSERVABILITY (Optional)
# ============================================================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# OpenTelemetry Configuration (Optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=

# Service name for telemetry
OTEL_SERVICE_NAME=rtp-agent

# Trace Sampling (0.0 to 1.0, where 1.0 = all traces)
OTEL_SAMPLER_ARG=0.1


# ============================================================================
# APPLICATION CONFIGURATION (Optional)
# ============================================================================

# Agent Configuration
AGENT_NAME=rtp-agent-default
AGENT_LOG_LEVEL=info

# Audio Configuration
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Endpointing/Turn-Taking Configuration (in seconds)
MIN_ENDPOINTING_DELAY=0.4
MAX_ENDPOINTING_DELAY=1.0
MIN_CONSECUTIVE_SPEECH_DELAY=0.1

# Turn Detection Mode (stt, vad, realtime_llm, manual)
TURN_DETECTION_MODE=stt

# Allow user interruptions during agent speech
ALLOW_INTERRUPTIONS=true

# User away timeout (in seconds)
USER_AWAY_TIMEOUT=30


# ============================================================================
# ADVANCED / EXPERIMENTAL (Optional)
# ============================================================================

# Node.js/ComfyUI Integration (for specialist models)
COMFYUI_API_URL=http://localhost:8188

# Remote LLM Context (for distributed deployments)
# REMOTE_CHAT_CONTEXT_URL=https://context-service.example.com

# Model Context Protocol (MCP) Integration
# MCP_SERVERS=[] # JSON array of MCP server configurations

# Realtime API Support (for very low-latency scenarios)
REALTIME_API_ENABLED=false

# ============================================================================
# NOTES
# ============================================================================
# 1. REQUIRED: LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET
# 2. REQUIRED: At least one set of LLM, STT, and TTS credentials
# 3. Use strong, unique API keys from each provider
# 4. Never commit .env to version control
# 5. For security, use environment variable management systems in production
#    (AWS Secrets Manager, HashiCorp Vault, etc)
# 6. Rotate API keys regularly and monitor usage
# ============================================================================
