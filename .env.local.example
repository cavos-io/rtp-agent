# ============================================================================
# LOCAL DEVELOPMENT EXAMPLE - .env.local.example
# ============================================================================
# This is an example of a typical local development setup using OpenAI services
# Copy to .env or .env.local and update with your actual API keys
# ============================================================================

# LiveKit (local or remote)
LIVEKIT_URL=wss://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# OpenAI (LLM, STT, TTS)
OPENAI_API_KEY=sk-your-actual-openai-key

# Logging
LOG_LEVEL=debug
OTEL_SERVICE_NAME=rtp-agent-local

# Audio Settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Agent Config
AGENT_NAME=local-test-agent
TURN_DETECTION_MODE=stt
ALLOW_INTERRUPTIONS=true
MIN_ENDPOINTING_DELAY=0.4
MAX_ENDPOINTING_DELAY=1.0
